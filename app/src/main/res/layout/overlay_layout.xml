<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/overlay_scrim"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <LinearLayout
        android:id="@+id/heardRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="56dp"
            android:text="@string/label_heard"
            android:textColor="@color/overlay_text"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/heardText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/overlay_text"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/meansRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="56dp"
            android:text="@string/label_means"
            android:textColor="@color/overlay_text"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/meansText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/overlay_text"
            android:textSize="14sp"
            android:textStyle="italic" />
    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="8dp"
        android:background="#33FFFFFF"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="56dp"
            android:text="@string/label_say"
            android:textColor="@color/overlay_text"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/replyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/overlay_waiting"
            android:textColor="@color/overlay_text"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
